NODE_ENV=production

API_PORT=8080
WEB_HTTP_PORT=18810

REDIS_URL=redis://redis:6379

# Public HTTPS URL of the web app.
# Example: https://raid.example.com
TELEGRAM_WEB_APP_URL=https://raid.example.com
TELEGRAM_MINI_APP_URL=https://t.me/raidbossts_bot/raid

# Same public origin. Do not use localhost on VPS.
# The browser will call https://raid.example.com/bosses, /raids, /socket.io.
VITE_API_URL=https://raid.example.com

# Secret. Put the real token only into .env.production, never into git.
TELEGRAM_BOT_TOKEN=

